{
  "id": null,
  "uid": "aitpg-brain",
  "title": "AITPG - Brain (LLM + Agents)",
  "tags": ["aitpg"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "title": "LLM Call Rate (calls/s)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {
          "expr": "sum(rate(aitpg_llm_calls_total[2m])) by (model, outcome)",
          "legendFormat": "{{model}} {{outcome}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "reqps"}
      }
    },
    {
      "id": 2,
      "title": "LLM Token Consumption (tokens/s)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {
          "expr": "sum(rate(aitpg_llm_tokens_total[2m])) by (model, direction)",
          "legendFormat": "{{model}} {{direction}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "short"}
      }
    },
    {
      "id": 3,
      "title": "LLM Latency p50 / p95",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(aitpg_llm_latency_seconds_bucket[5m])) by (le, model))",
          "legendFormat": "{{model}} p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(aitpg_llm_latency_seconds_bucket[5m])) by (le, model))",
          "legendFormat": "{{model}} p95",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "s"}
      }
    },
    {
      "id": 4,
      "title": "Agent Run Rate (runs/s)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {
          "expr": "sum(rate(aitpg_agent_runs_total[2m])) by (agent, outcome)",
          "legendFormat": "{{agent}} {{outcome}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "short"}
      }
    },
    {
      "id": 5,
      "title": "Agent Duration p95 (s)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(aitpg_agent_duration_seconds_bucket[5m])) by (le, agent))",
          "legendFormat": "{{agent}} p95",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "s"}
      }
    },
    {
      "id": 6,
      "title": "Ingestion — Documents (docs/s)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {
          "expr": "sum(rate(aitpg_ingest_docs_total[5m])) by (kind, outcome)",
          "legendFormat": "{{kind}} {{outcome}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "short"}
      }
    },
    {
      "id": 7,
      "title": "Ingestion — Chunks (chunks/s)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 24},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {
          "expr": "rate(aitpg_ingest_chunks_total[5m])",
          "legendFormat": "chunks/s",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "short"}
      }
    },
    {
      "id": 8,
      "title": "LLM Error Rate",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 24},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {
          "expr": "sum(rate(aitpg_llm_calls_total{outcome=\"error\"}[5m])) / sum(rate(aitpg_llm_calls_total[5m]))",
          "legendFormat": "Error rate",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "percentunit"}
      }
    }
  ],
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "label": "Datasource",
        "current": {}
      }
    ]
  },
  "time": {"from": "now-1h", "to": "now"}
}
