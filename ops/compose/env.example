# AI Test Plan Generator — compose environment template
# Copy this file to .env at the repository root and fill in real values.
# docker-compose.yml reads that root .env file. Per-service environment blocks
# override service-discovery URLs (redis/qdrant/neo4j hostnames).

# ---------------------------------------------------------------------------
# LLM routing (provider-agnostic via LiteLLM)
# ---------------------------------------------------------------------------
LLM_MODEL_SMART=claude-opus-4-1-20250805
LLM_MODEL_BALANCED=claude-sonnet-4-5-20250929
LLM_MODEL_FAST=claude-haiku-4-5-20251001
LLM_MODEL_EMBEDDING=text-embedding-3-large

# Provider credentials — set only the one you use.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
VERTEXAI_PROJECT=
AWS_REGION_NAME=

# ---------------------------------------------------------------------------
# LLM runtime knobs
# ---------------------------------------------------------------------------
LLM_DEFAULT_TEMPERATURE=0.1
LLM_MAX_RETRIES=4
LLM_REQUEST_TIMEOUT_S=120

# ---------------------------------------------------------------------------
# Ingestion
# ---------------------------------------------------------------------------
CHUNK_TARGET_TOKENS=900
CHUNK_OVERLAP_TOKENS=120
MAX_DOC_PAGES_WARN=12000

# ---------------------------------------------------------------------------
# Memory backends
# Overridden per-service in docker-compose.yml to point at compose services.
# ---------------------------------------------------------------------------
SEMANTIC_MEMORY_BACKEND=qdrant
EPISODIC_MEMORY_BACKEND=sqlite
CROSSDOC_GRAPH_BACKEND=networkx

# ---------------------------------------------------------------------------
# Qdrant (QDRANT_URL is overridden to http://qdrant:6333 in compose)
# ---------------------------------------------------------------------------
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=
QDRANT_EMBEDDING_DIM=3072
QDRANT_COLLECTION_PREFIX=aitpg

# ---------------------------------------------------------------------------
# SQLite episodic store
# ---------------------------------------------------------------------------
SQLITE_EPISODIC_PATH=data/episodic.db

# ---------------------------------------------------------------------------
# Neo4j (NEO4J_URI overridden to bolt://neo4j:7687 in compose)
# ---------------------------------------------------------------------------
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme
NEO4J_AUTH=neo4j/changeme

# ---------------------------------------------------------------------------
# Blob store
# ---------------------------------------------------------------------------
BLOB_STORE_BACKEND=local
BLOB_STORE_LOCAL_ROOT=./data/blobs
S3_BUCKET=
S3_REGION=us-east-1

# ---------------------------------------------------------------------------
# HTTP API
# ---------------------------------------------------------------------------
API_DEBUG=false
API_CORS_ORIGINS=["http://localhost:8080","http://localhost:5173"]
APP_DB_PATH=data/app.db
MAX_UPLOAD_SIZE_BYTES=104857600
LARGE_DOC_THRESHOLD_BYTES=5242880

# ---------------------------------------------------------------------------
# JWT authentication (M13)
# ---------------------------------------------------------------------------
JWT_ALGORITHM=HS256
JWT_PRIVATE_KEY_PATH=
JWT_PUBLIC_KEY_PATH=
# Replace before deployment. Must be non-default and at least 32 characters
# when API_DEBUG=false and JWT_PRIVATE_KEY_PATH is not set.
JWT_SECRET=replace-with-at-least-32-random-characters
JWT_ACCESS_TOKEN_TTL_SECONDS=900
JWT_REFRESH_TOKEN_TTL_SECONDS=1209600

# ---------------------------------------------------------------------------
# Redis job queue + event broker
# REDIS_URL is overridden to redis://redis:6379/0 in compose.
# ---------------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0
JOB_WORKER_CONCURRENCY=4
EVENT_BROKER_BACKEND=redis

# ---------------------------------------------------------------------------
# Blob encryption at rest (M16) — leave blank to disable
# ---------------------------------------------------------------------------
BLOB_ENCRYPTION_KEY=
BLOB_KEK_VERSION=v1

# ---------------------------------------------------------------------------
# OpenTelemetry tracing (M20)
# OTEL_EXPORTER_OTLP_ENDPOINT is overridden to http://jaeger:4318 in compose.
# ---------------------------------------------------------------------------
OTEL_ENABLED=false
OTEL_SERVICE_NAME=aitpg-api
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4318

# ---------------------------------------------------------------------------
# Prometheus metrics (M21)
# ---------------------------------------------------------------------------
METRICS_ENABLED=true

# ---------------------------------------------------------------------------
# Structured logging (M22)
# ---------------------------------------------------------------------------
LOG_FORMAT=json
LOG_LEVEL=INFO

# ---------------------------------------------------------------------------
# LLM cost tracking (M23)
# ---------------------------------------------------------------------------
COST_TRACKING_ENABLED=true

# ---------------------------------------------------------------------------
# Grafana admin password (observability profile only)
# ---------------------------------------------------------------------------
GRAFANA_ADMIN_PASSWORD=admin
