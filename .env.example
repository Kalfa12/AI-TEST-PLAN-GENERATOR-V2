# --- LLM routing (provider-agnostic via LiteLLM) --------------------------
# Swap any of these to a different provider/model without touching code:
#   Anthropic:  claude-opus-4-1-20250805  / claude-sonnet-4-5-20250929
#   OpenAI:     gpt-5 / gpt-5-mini
#   Google:     vertex_ai/gemini-2.5-pro / gemini/gemini-2.5-flash
#   Local:      ollama/llama3.3 / ollama_chat/qwen2.5:72b
#   AWS:        bedrock/anthropic.claude-3-5-sonnet-20241022-v2:0
LLM_MODEL_SMART=gemini/gemma-4-31b-it
LLM_MODEL_BALANCED=gemini/gemma-4-31b-it
LLM_MODEL_FAST=gemini/gemma-4-31b-it
LLM_MODEL_EMBEDDING=gemini/gemini-embedding-001

# Provider credentials (only the one you use needs to be set).
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
VERTEXAI_PROJECT=
AWS_REGION_NAME=

# --- Runtime knobs --------------------------------------------------------
LLM_DEFAULT_TEMPERATURE=0.1
LLM_MAX_RETRIES=4
LLM_REQUEST_TIMEOUT_S=120

# --- Ingestion -----------------------------------------------------------
CHUNK_TARGET_TOKENS=900
CHUNK_OVERLAP_TOKENS=120
MAX_DOC_PAGES_WARN=12000

# --- Memory backends (abstract now, concrete later) ----------------------
# Reference in-memory impls are used when these are blank.
SEMANTIC_MEMORY_BACKEND=inmemory       # inmemory | qdrant | chroma | pgvector
EPISODIC_MEMORY_BACKEND=inmemory       # inmemory | sqlite | redis
CROSSDOC_GRAPH_BACKEND=networkx        # networkx | neo4j

# --- Qdrant settings (used when SEMANTIC_MEMORY_BACKEND=qdrant) ----------
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_EMBEDDING_DIM=3072
QDRANT_COLLECTION_PREFIX=aitpg   # prefix for all collections; change per env to share a cluster

# --- SQLite settings (used when EPISODIC_MEMORY_BACKEND=sqlite) ----------
SQLITE_EPISODIC_PATH=data/episodic.db

# --- Neo4j settings (used when CROSSDOC_GRAPH_BACKEND=neo4j) -------------
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme

# --- Blob store settings (M04) -------------------------------------------
BLOB_STORE_BACKEND=local         # local | s3
BLOB_STORE_LOCAL_ROOT=./data/blobs
S3_BUCKET=
S3_REGION=us-east-1

# --- HTTP API settings (M05) -----------------------------------------------
API_DEBUG=true
API_CORS_ORIGINS=["*"]           # Dev only. In production use explicit origins.
APP_DB_PATH=data/app.db          # SQLite db for projects/users (M10)
MAX_UPLOAD_SIZE_BYTES=104857600  # 100 MB
LARGE_DOC_THRESHOLD_BYTES=5242880  # 5 MB — above this, ingest is backgrounded

# --- JWT authentication settings (M13) ------------------------------------
# Algorithm: RS256 for production (needs key files), HS256 for local dev.
JWT_ALGORITHM=RS256
# Paths to PEM-encoded RSA key pair (RS256 mode). Leave blank to use HS256.
JWT_PRIVATE_KEY_PATH=
JWT_PUBLIC_KEY_PATH=
# Shared secret for HS256 fallback (local dev only — do NOT use in production).
JWT_SECRET=changeme-local-dev-only-secret!!
# Access token TTL in seconds (default 15 min).
JWT_ACCESS_TOKEN_TTL_SECONDS=900
# Refresh token TTL in seconds (default 14 days).
JWT_REFRESH_TOKEN_TTL_SECONDS=1209600

# --- Redis (M17/M18) — required when using ARQ job queue or Redis event broker --
# Used by: ARQ worker, RedisPubSubBroker (when EVENT_BROKER_BACKEND=redis).
REDIS_URL=redis://localhost:6379/0
# Maximum concurrent jobs per ARQ worker process.
JOB_WORKER_CONCURRENCY=4
# Event broker backend: "inmemory" (default, tests) or "redis" (production).
EVENT_BROKER_BACKEND=inmemory

# --- Blob encryption at rest (M16) ----------------------------------------
# Base64url-encoded 32-byte Fernet key. Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Leave blank to disable encryption.
BLOB_ENCRYPTION_KEY=
# KEK version prefix stored alongside each encrypted blob key.
BLOB_KEK_VERSION=v1

# --- OpenTelemetry tracing (M20) ------------------------------------------
# Set OTEL_ENABLED=true to activate tracing. Requires an OTLP-compatible
# collector (Jaeger, Tempo, etc.) reachable at OTEL_EXPORTER_OTLP_ENDPOINT.
OTEL_ENABLED=false
OTEL_SERVICE_NAME=aitpg-api
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# --- Prometheus metrics (M21) ----------------------------------------------
# Set METRICS_ENABLED=false to disable the /metrics endpoint.
METRICS_ENABLED=true

# --- Structured logging (M22) ----------------------------------------------
# LOG_FORMAT=json for production log shipping; console for local dev.
LOG_FORMAT=console
LOG_LEVEL=INFO

# --- LLM cost tracking (M23) -----------------------------------------------
# Tracks per-session LLM token usage and estimated cost in the app SQLite DB.
COST_TRACKING_ENABLED=true
