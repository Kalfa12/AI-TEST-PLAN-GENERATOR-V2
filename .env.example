# --- LLM routing (provider-agnostic via LiteLLM) --------------------------
# Swap any of these to a different provider/model without touching code:
#   Anthropic:  claude-opus-4-1-20250805  / claude-sonnet-4-5-20250929
#   OpenAI:     gpt-5 / gpt-5-mini
#   Google:     vertex_ai/gemini-2.5-pro / gemini/gemini-2.5-flash
#   Local:      ollama/llama3.3 / ollama_chat/qwen2.5:72b
#   AWS:        bedrock/anthropic.claude-3-5-sonnet-20241022-v2:0
LLM_MODEL_SMART=claude-opus-4-1-20250805
LLM_MODEL_BALANCED=claude-sonnet-4-5-20250929
LLM_MODEL_FAST=claude-haiku-4-5-20251001
LLM_MODEL_EMBEDDING=text-embedding-3-large

# Provider credentials (only the one you use needs to be set).
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
VERTEXAI_PROJECT=
AWS_REGION_NAME=

# --- Runtime knobs --------------------------------------------------------
LLM_DEFAULT_TEMPERATURE=0.1
LLM_MAX_RETRIES=4
LLM_REQUEST_TIMEOUT_S=120

# --- Ingestion -----------------------------------------------------------
CHUNK_TARGET_TOKENS=900
CHUNK_OVERLAP_TOKENS=120
MAX_DOC_PAGES_WARN=12000

# --- Memory backends (abstract now, concrete later) ----------------------
# Reference in-memory impls are used when these are blank.
SEMANTIC_MEMORY_BACKEND=inmemory       # inmemory | qdrant | chroma | pgvector
EPISODIC_MEMORY_BACKEND=inmemory       # inmemory | sqlite | redis
CROSSDOC_GRAPH_BACKEND=networkx        # networkx | neo4j

# --- Qdrant settings (used when SEMANTIC_MEMORY_BACKEND=qdrant) ----------
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_EMBEDDING_DIM=3072
QDRANT_COLLECTION_PREFIX=aitpg   # prefix for all collections; change per env to share a cluster

# --- SQLite settings (used when EPISODIC_MEMORY_BACKEND=sqlite) ----------
SQLITE_EPISODIC_PATH=data/episodic.db

# --- Neo4j settings (used when CROSSDOC_GRAPH_BACKEND=neo4j) -------------
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme

# --- Blob store settings (M04) -------------------------------------------
BLOB_STORE_BACKEND=local         # local | s3
BLOB_STORE_LOCAL_ROOT=./data/blobs
S3_BUCKET=
S3_REGION=us-east-1
