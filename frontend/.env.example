# Base URL for the FastAPI backend. Vite proxies /api -> this in dev.
VITE_API_BASE_URL=http://localhost:8000
# For the Docker/nginx frontend, use same-origin proxy paths:
# VITE_API_BASE_URL=/api

# WebSocket base URL for the chat copilot (M27).
VITE_WS_BASE_URL=ws://localhost:8000
# For the Docker/nginx frontend, use:
# VITE_WS_BASE_URL=/ws

# When true the OpenAPI client is regenerated against this URL in CI.
VITE_OPENAPI_URL=http://localhost:8000/openapi.json
